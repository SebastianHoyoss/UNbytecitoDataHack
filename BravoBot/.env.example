APP_ENV=local
APP_NAME=BravoBot
APP_VERSION=0.1.0
BASE_URL=https://pascualbravo.edu.co/
USER_AGENT=BravoBot/0.1 (+https://pascualbravo.edu.co/; contact: dev@bravobot.local)
SCRAPE_DELAY_SECONDS=1.0
MAX_PAGES=120
CHUNK_SIZE=1200
CHUNK_OVERLAP=180
RAG_TOP_K=5
SIMILARITY_THRESHOLD=0.24
RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TEMPERATURE=0.1
GROQ_MAX_TOKENS=700
GROQ_REQUEST_TIMEOUT=60
GROQ_MAX_RETRIES=2
GROQ_API_KEY=
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX_NAME=bravobot-index
PINECONE_NAMESPACE=bravobot
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
API_BASE_URL=http://localhost:8000
ALLOW_LOCAL_VECTORSTORE=true
DATA_DIR=data
RAW_DIR=data/raw
PROCESSED_DIR=data/processed
LOGS_DIR=logs
RAW_MANIFEST_NAME=raw_manifest.json
PROCESSED_MANIFEST_NAME=index_manifest.json
BRAVOBOT_API_URL=http://localhost:8000
